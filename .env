# =================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =================================================================
PROJECT_NAME="API REST Usuarios"
DEBUG=True
VERSION=1.0.0
ENVIRONMENT=development
API_V1_STR=/api

# =================================================================
# CONFIGURACIÓN DE POSTGRESQL (DOCKER)
# =================================================================
# Estas variables son utilizadas tanto por Docker Compose como por la App
POSTGRES_USER=admin_user
POSTGRES_PASSWORD=cambiame_por_algo_seguro
POSTGRES_DB=fastapi_db
POSTGRES_PORT=5432

# La URL de conexión utiliza el nombre del servicio de Docker ("db") como host
# Se utiliza el driver asyncpg para soporte asíncrono en FastAPI
# En la URL se utiliza @db para referirse al contenedor de la base de datos 
# definido en docker-compose.yml, si no se usaran contenedores para la base de datos
# y el ambiente de desarrollo, se podría usar localhost en su lugar (Sin usar 
# Networks de Docker).
#DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:${POSTGRES_PORT}/${POSTGRES_DB}


# =================================================================
# CONFIGURACIÓN DE LA APLICACIÓN (FASTAPI)
# =================================================================
# Esta variable es utilizada por Docker Compose
APP_PORT=8000
# =================================================================
# SEGURIDAD Y AUTENTICACIÓN
# =================================================================
SECRET_KEY=clave_secreta_super_segura_aqui_cambiar_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =================================================================
# CONFIGURACIÓN DE LA API Y CORS
# =================================================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

